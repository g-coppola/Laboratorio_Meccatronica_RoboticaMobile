<?xml version="1.0"?>
<robot name="x500_drone">
  <material name="ccw_prop_color">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  
  <material name="cw_prop_color">
    <color rgba="0.1 0.1 0.8 1.0"/>
  </material>

  <link name="base_link">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.021666" ixy="0" ixz="0" iyy="0.021666" iyz="0" izz="0.040000"/>
    </inertial>

    <visual name="base_link_visual">
      <origin xyz="0 0 0.025" rpy="0 0 3.141592"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/NXP-HGD-CF.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <visual name="5010_motor_base_0">
      <origin xyz="0.174 0.174 0.032" rpy="0 0 -0.45"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/5010Base.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <visual name="5010_motor_base_1">
      <origin xyz="-0.174 0.174 0.032" rpy="0 0 -0.45"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/5010Base.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <visual name="5010_motor_base_2">
      <origin xyz="0.174 -0.174 0.032" rpy="0 0 -0.45"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/5010Base.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <visual name="5010_motor_base_3">
      <origin xyz="-0.174 -0.174 0.032" rpy="0 0 -0.45"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/5010Base.dae" scale="1 1 1"/>
      </geometry>
    </visual>

    <collision name="base_link_collision_0">
      <origin xyz="0 0 0.007" rpy="0 0 0"/>
      <geometry>
        <box size="0.3535 0.3535 0.05"/>
      </geometry>
    </collision>
    <collision name="base_link_collision_1">
      <origin xyz="0 -0.098 -0.123" rpy="-0.35 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.21"/>
      </geometry>
    </collision>
    <collision name="base_link_collision_2">
      <origin xyz="0 0.098 -0.123" rpy="0.35 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.21"/>
      </geometry>
    </collision>
    <collision name="base_link_collision_3">
      <origin xyz="0 -0.132 -0.2195" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.015 0.015"/>
      </geometry>
    </collision>
    <collision name="base_link_collision_4">
      <origin xyz="0 0.132 -0.2195" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.015 0.015"/>
      </geometry>
    </collision>
  </link>

  <link name="rotor_0">
    <inertial>
      <mass value="0.01607"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="3.846e-07" ixy="0" ixz="0" iyy="2.611e-05" iyz="0" izz="2.649e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.022 -0.146 -0.016" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/1345_prop_ccw.stl" scale="0.846 0.846 0.846"/>
      </geometry>
      <material name="ccw_prop_color"/>
    </visual>
    <visual name="rotor_0_visual_motor_bell">
      <origin xyz="0 0 -0.032" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/5010Bell.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.279 0.016 0.0008"/>
      </geometry>
    </collision>
  </link>

  <joint name="rotor_0_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_0"/>
    <origin xyz="0.174 -0.174 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <gazebo>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
  </gazebo>
  
  <gazebo reference="rotor_0"><material>Gazebo/Red</material></gazebo>

  <link name="rotor_1">
    <inertial>
      <mass value="0.01607"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="3.846e-07" ixy="0" ixz="0" iyy="2.611e-05" iyz="0" izz="2.649e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.022 -0.146 -0.016" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/1345_prop_ccw.stl" scale="0.846 0.846 0.846"/>
      </geometry>
      <material name="ccw_prop_color"/>
    </visual>
    <visual name="rotor_1_visual_motor_bell">
      <origin xyz="0 0 -0.032" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/5010Bell.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.279 0.016 0.0008"/>
      </geometry>
    </collision>
  </link>

  <joint name="rotor_1_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_1"/>
    <origin xyz="-0.174 0.174 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <gazebo>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
  </gazebo>

  <gazebo reference="rotor_1"><material>Gazebo/Red</material></gazebo>

  <link name="rotor_2">
    <inertial>
      <mass value="0.01607"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="3.846e-07" ixy="0" ixz="0" iyy="2.611e-05" iyz="0" izz="2.649e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.022 -0.146 -0.016" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/1345_prop_cw.stl" scale="0.846 0.846 0.846"/>
      </geometry>
      <material name="cw_prop_color"/>
    </visual>
    <visual name="rotor_2_visual_motor_bell">
      <origin xyz="0 0 -0.032" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/5010Bell.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.279 0.016 0.0008"/>
      </geometry>
    </collision>
  </link>

  <joint name="rotor_2_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_2"/>
    <origin xyz="0.174 0.174 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <gazebo>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
  </gazebo>

  <gazebo reference="rotor_2"><material>Gazebo/Blue</material></gazebo>

  <link name="rotor_3">
    <inertial>
      <mass value="0.01607"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="3.846e-07" ixy="0" ixz="0" iyy="2.611e-05" iyz="0" izz="2.649e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.022 -0.146 -0.016" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/1345_prop_cw.stl" scale="0.846 0.846 0.846"/>
      </geometry>
      <material name="cw_prop_color"/>
    </visual>
    <visual name="rotor_3_visual_motor_bell">
      <origin xyz="0 0 -0.032" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://drone_test/meshes/5010Bell.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.279 0.016 0.0008"/>
      </geometry>
    </collision>
  </link>

  <joint name="rotor_3_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rotor_3"/>
    <origin xyz="-0.174 -0.174 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <gazebo>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1000.0</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
  </gazebo>

  <gazebo reference="rotor_3"><material>Gazebo/Blue</material></gazebo>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.08 0.02"/> 
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.08 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.18 0 0.05" rpy="0 0 0"/> 
  </joint>

  <link name="camera_optical_link">
    <inertial>
      <mass value="1e-5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <ignition_frame_id>camera_optical_link</ignition_frame_id>
      <always_on>true</always_on>
      <update_rate>15</update_rate> 
      <visualize>true</visualize>
      <topic>camera</topic>
      <camera>
        <horizontal_fov>1.50098</horizontal_fov> 
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.3</near>
          <far>15.0</far> 
        </clip>
        </camera>
    </sensor>
  </gazebo>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/> 
  </joint>

  <gazebo reference="lidar_link">
    <sensor name='gpu_lidar' type='gpu_lidar'>
      <ignition_frame_id>lidar_link</ignition_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <topic>scan_cloud</topic> 
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.261799</min_angle>
            <max_angle>0.261799</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.4</min>
          <max>15.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>100</update_rate>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_publish_frequency>50</odom_publish_frequency>
      <dimensions>3</dimensions>
      <odom_topic>/gazebo/ground_truth/odometry</odom_topic>
      <tf_topic>/model/x500_drone/pose</tf_topic>
      <publish_tf>true</publish_tf>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>rotor_0_joint</joint_name>
      <joint_name>rotor_1_joint</joint_name>
      <joint_name>rotor_2_joint</joint_name>
      <joint_name>rotor_3_joint</joint_name>
    </plugin>
  </gazebo>

</robot>