      <pose>1.0 -6.0 0.09 0 0 1.5708</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf</uri>
    </include>
    <include>
      <name>shelf_5</name>
      <pose>1.0 10.0 0.09 0 0 1.5708</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf</uri>
    </include>
    <include>
      <name>shelf_6</name>
      <pose>-1.0 10.0 0.09 0 0 1.5708</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf</uri>
    </include>
    <include>
      <name>shelf_7</name>
