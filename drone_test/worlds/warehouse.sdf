      <pose>5.0 13.0 0.0 0 0 0.0</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf_big</uri>
    </include>
    <include>
      <name>big_shelf_4</name>
      <pose>5.0 -10.0 0.0 0 0 0.0</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf_big</uri>
    </include>
    <include>
      <name>big_shelf_5</name>
      <pose>-12.0 11.0 0.0 0 0 0.0</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf_big</uri>
    </include>
    <include>
      <name>big_shelf_6</name>
      <pose>-12.0 -7.0 0.0 0 0 0.0</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf_big</uri>
    </include>
    <include>
      <name>big_shelf_7</name>
      <pose>-4.0 13.0 0.0 0 0 0.0</pose>
