    <include>
      <name>big_shelf_8</name>
      <pose>-4.0 -10.0 0.0 0 0 0.0</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf_big</uri>
    </include>

    <include>
      <name>shelf_1</name>
      <pose>1.0 -10.0 0.09 0 0 1.5708</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf</uri>
    </include>
    <include>
      <name>shelf_2</name>
      <pose>-1.0 -10.0 0.09 0 0 1.5708</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf</uri>
    </include>
    <include>
      <name>shelf_3</name>
      <pose>-1.0 -6.0 0.09 0 0 1.5708</pose>
      <uri>https://fuel.gazebosim.org/1.0/MovAi/models/shelf</uri>
    </include>
    <include>
